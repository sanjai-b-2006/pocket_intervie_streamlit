# --- Coach: Gemma 4 (via OpenRouter until Gemma 4 lands on Fireworks) ---
FIREWORKS_API_KEY=your_api_key_here
FIREWORKS_BASE_URL=https://openrouter.ai/api/v1
GEMMA_MODEL=google/gemma-4-26b-a4b-it

# --- Independent hiring manager: a Fireworks-hosted model on AMD Instinct GPUs ---
# This is what puts your Fireworks/AMD credits to work. Use your Fireworks key here.
# Leave JUDGE_API_KEY blank to disable the verdict + answer-rewrite features gracefully.
JUDGE_API_KEY=your_fireworks_api_key_here
JUDGE_BASE_URL=https://api.fireworks.ai/inference/v1
JUDGE_MODEL=accounts/fireworks/models/gpt-oss-120b

# Local ASR (faster-whisper). Use "tiny" on memory-constrained hosts.
ASR_DEVICE=cpu
ASR_MODEL_SIZE=base
ASR_COMPUTE_TYPE=int8

# Set to false on memory-constrained hosts to skip librosa's numba-JIT pitch analysis pass.
ENABLE_PITCH_ANALYSIS=true
